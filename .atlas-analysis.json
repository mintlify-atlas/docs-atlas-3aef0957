  "keyFeatures": [
    "Composable feature system — mix and match playback, volume, time, fullscreen, PiP, text tracks, and more",
    "Multi-platform — React components, HTML custom elements, and React Native support",
    "Presets — pre-configured bundles for video, audio, and background playback use cases",
    "Prebuilt skins — complete player UIs with accessible controls and CSS customization",
    "HLS and DASH streaming — built-in support via hls.js and dash.js",
    "TypeScript-first — full type safety with generics, selectors, and strict mode",
    "Reactive state management — selector-based subscriptions with minimal re-renders",
    "Tree-shakeable — only bundle the features and components your player needs"
  ],
  "publicApiSurface": [
    "createPlayer() — @videojs/react and @videojs/html",
    "createPlayer() — @videojs/html (HTML custom elements)",
    "usePlayer() hook — access player state and actions in React",
    "useMedia() hook — access the underlying media element",
    "useSelector() / useStore() — @videojs/store React bindings",
    "Player.Provider / Player.Container — React context components",
    "PlayButton, MuteButton, FullscreenButton, PiPButton — React UI components",
    "SeekButton, CaptionsButton, PlaybackRateButton — React UI components",
    "TimeSlider, VolumeSlider, Slider — React slider components",
    "BufferingIndicator, Poster, Thumbnail, Time — React display components",
    "Controls, Tooltip, Popover, AlertDialog — React layout/overlay components",
    "PlayerController, SnapshotController, StoreController — HTML custom element controllers",
    "ProviderMixin, ContainerMixin — HTML custom element mixins",
    "playback, volume, time, fullscreen, pip, source — feature objects",
    "textTracks, playbackRate, controls, error, buffer — feature objects",
    "videoFeatures, audioFeatures, backgroundFeatures — feature bundles",
    "createSelector(), shallowEqual() — @videojs/store selectors",
    "@videojs/spf — Stream Processing Framework for HLS/DASH"
  ]
